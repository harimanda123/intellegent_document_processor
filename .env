# ── LLM Configuration ─────────────────────────────────────────────────
# Change provider and model without touching any code

# Option 1: Groq (fast, free tier available)
# LLM_PROVIDER=groq
# LLM_API_KEY=your-groq-api-key-here
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=

# Option 2: Ollama (local, no API key needed)
# LLM_PROVIDER=ollama
# LLM_API_KEY=ollama
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434

# Option 3: OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=

# Option 4: Anthropic
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_BASE_URL=

# Option 5: Any OpenAI-compatible (vLLM, LM Studio, Together AI)
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=your-key
# LLM_MODEL=your-model-name
# LLM_BASE_URL=https://your-custom-endpoint.com

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./idp.db

# ── App ────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Review ─────────────────────────────────────────────────────────────
# Used when require_review="auto" (ERP) or auto-review mode is enabled.
# Documents with avg extraction confidence below this threshold are
# routed to PENDING_REVIEW instead of being auto-delivered.
AUTO_REVIEW_THRESHOLD=0.80

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the UI.
CORS_ORIGINS=http://localhost:5173